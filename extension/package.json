{
  "repository": {
    "type": "git",
    "url": "https://github.com/AllenJohnn/Codus"
  },
  "homepage": "https://allenjohnnportfolio.vercel.app/",
  "bugs": {
    "url": "https://github.com/AllenJohnn/Codus/issues"
  },
  "name": "codus",
  "displayName": "Codus",
  "description": "Code together, live. Room-based collaboration for VS Code.",
  "version": "0.2.0",
  "publisher": "codus-dev",
  "license": "MIT",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "collaboration",
    "collab",
    "live share",
    "pair programming",
    "rooms",
    "real-time",
    "sync",
    "cursor sharing",
    "chat",
    "multiplayer"
  ],

  "activationEvents": [
    "onStartupFinished",
    "onView:codus.sidebarView",
    "onCommand:codus.createRoom",
    "onCommand:codus.joinRoom",
    "onCommand:codus.leaveRoom",
    "onUri"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "media/**",
    "images/icon.png",
    "src/webview/index.html",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codus.createRoom",
        "title": "Create Room"
      },
      {
        "command": "codus.joinRoom",
        "title": "Join Room"
      },
      {
        "command": "codus.leaveRoom",
        "title": "Leave Room"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codusSidebar",
          "title": "Codus",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "codusSidebar": [
        {
          "type": "webview",
          "id": "codus.sidebarView",
          "name": "Codus Room"
        }
      ]
    },
    "configuration": {
      "title": "Codus",
      "properties": {
        "codus.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3000",
          "description": "URL of the Codus collaboration server"
        }
      }
    },
    "uriHandler": true
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run typecheck && npm run bundle",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/extension.js",
    "watch": "tsc -p tsconfig.json -w",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "package": "npx @vscode/vsce package --allow-missing-repository --skip-license --no-dependencies",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "socket.io-client": "^4.8.1",
    "uuid": "^11.1.0",
    "yjs": "^13.6.26"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.88.0",
    "esbuild": "^0.25.4",
    "typescript": "^5.8.3"
  }
}
