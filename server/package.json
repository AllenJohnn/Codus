{
	"name": "codus-server",
	"version": "0.1.0",
	"private": true,
	"main": "dist/index.js",
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "tsc",
		"watch": "tsc -p tsconfig.json -w",
		"start": "node dist/index.js",
		"dev": "ts-node src/index.ts",
		"lint": "eslint src",
		"format": "prettier --write src",
		"clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
	},
	"dependencies": {
		"codus-shared": "file:../shared",
		"express": "^4.21.2",
		"socket.io": "^4.8.1",
		"uuid": "^11.1.0",
		"yjs": "^13.6.26"
	},
	"devDependencies": {
		"@eslint/js": "^9.25.1",
		"@typescript-eslint/eslint-plugin": "^8.30.1",
		"@typescript-eslint/parser": "^8.30.1",
		"@types/express": "^4.17.23",
		"@types/node": "^22.15.29",
		"eslint": "^9.25.1",
		"globals": "^16.0.0",
		"prettier": "^3.5.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.8.3"
	}
}
