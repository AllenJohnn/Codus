{
  "name": "codus",
  "displayName": "Codus — Collaborative Coding",
  "description": "Real-time collaborative code editing for VS Code. Share a 4-digit room code, sync live with teammates — no account needed.",
  "version": "0.5.3",
  "publisher": "AllenJohn",
  "license": "MIT",
  "author": {
    "name": "Allen John"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AllenJohnn/Codus"
  },
  "bugs": {
    "url": "https://github.com/AllenJohnn/Codus/issues"
  },
  "homepage": "https://github.com/AllenJohnn/Codus/blob/main/extension/README.md",
  "galleryBanner": {
    "color": "#0f1117",
    "theme": "dark"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "collaboration",
    "live share",
    "pair programming",
    "real-time",
    "multiplayer",
    "sync",
    "remote",
    "collab",
    "cursor sharing",
    "chat"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codus.createRoom",
        "title": "Create Room",
        "category": "Codus"
      },
      {
        "command": "codus.joinRoom",
        "title": "Join Room",
        "category": "Codus"
      },
      {
        "command": "codus.leaveRoom",
        "title": "Leave Room",
        "category": "Codus"
      },
      {
        "command": "codus.connectionDiagnostics",
        "title": "Connection Diagnostics",
        "category": "Codus"
      },
      {
        "command": "codus.toggleFollow",
        "title": "Toggle Follow User",
        "category": "Codus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codusSidebar",
          "title": "Codus",
          "icon": "media/collab.svg"
        }
      ]
    },
    "views": {
      "codusSidebar": [
        {
          "type": "webview",
          "id": "codus.sidebarView",
          "name": "Codus Room"
        },
        {
          "type": "tree",
          "id": "codusUsersView",
          "name": "Room Users"
        }
      ]
    },
    "configuration": {
      "title": "Codus",
      "properties": {
        "codus.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "markdownDescription": "URL of the Codus collaboration server. Defaults to the free shared server. [Learn how to self-host](https://github.com/AllenJohnn/Codus#self-hosting)."
        },
        "codus.roomToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional room token for servers configured with CODUS_ROOM_TOKEN."
        }
      }
    },
    "uriHandler": true
  },
  "scripts": {
    "prebuild": "node ../scripts/verify-integrity.js",
    "prepackage": "node ../scripts/verify-integrity.js",
    "vscode:prepublish": "npm run build",
    "build": "npm run typecheck && npm run bundle && npm run bundle:server",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/extension.js",
    "bundle:server": "esbuild ../server/src/index.ts --bundle --platform=node --format=cjs --outfile=out/codus-server.js",
    "watch": "tsc -p tsconfig.json -w",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "package": "npx @vscode/vsce package --skip-license --no-dependencies"
  },
  "dependencies": {
    "socket.io-client": "^4.8.1",
    "uuid": "^11.1.0",
    "yjs": "^13.6.26"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.88.0",
    "esbuild": "^0.25.4",
    "typescript": "^5.8.3"
  }
}